# Multi-Tenant Invoice Backend Environment Configuration
# Copy this file to .env and configure with your actual values

# ============================================================================
# BASIC CONFIGURATION
# ============================================================================
NODE_ENV=development
PORT=8080

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority

# ============================================================================
# REDIS CONFIGURATION (REQUIRED for Event Bus & Queues)
# ============================================================================
# REDIS_URL=redis://:password@host:port (Prioritized if set)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password

# ============================================================================
# EMAIL CONFIGURATION  
# ============================================================================
APP_PASSWORD=your_gmail_app_password
ADMIN_EMAIL=admin@example.com

# ============================================================================
# FIREBASE CONFIGURATION
# ============================================================================
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY_ID=your-private-key-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_CLIENT_ID=your-client-id
FIREBASE_CLIENT_CERT_URL=https://www.googleapis.com/robot/v1/metadata/x509/firebase-adminsdk-xxxxx%40your-project.iam.gserviceaccount.com
# Firebase API key (used by backend to verify current password against Firebase Auth).
# This is project-level and can be the same value already used by your iOS/Android Firebase config.
FIREBASE_API_KEY=your-firebase-api-key

# ============================================================================
# SECURITY CONFIGURATION
# ============================================================================
JWT_SECRET=your-jwt-secret-key-here
JWT_EXPIRES_IN=24h
JWT_EXPIRY=1h
JWT_REFRESH_EXPIRY=7d
BCRYPT_ROUNDS=12

# ============================================================================
# RATE LIMITING CONFIGURATION
# ============================================================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_TIME_MS=900000

# ============================================================================
# PASSWORD POLICY CONFIGURATION
# ============================================================================
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_NUMBERS=true
PASSWORD_REQUIRE_SYMBOLS=true

# ============================================================================
# EXTERNAL DATA SOURCES
# ============================================================================
HOLIDAY_CSV=https://raw.githubusercontent.com/BishalBudhathoki/backend_rest_api/main/holiday.csv

# ============================================================================
# NDIS CATALOG AUTO-SYNC (OBJECT STORAGE -> MONGODB)
# ============================================================================
# Provider: r2 (Cloudflare R2) or gcs (Google Cloud Storage S3 interoperability)
NDIS_CATALOG_PROVIDER=r2
NDIS_CATALOG_BUCKET=your-reference-data-bucket
NDIS_CATALOG_OBJECT_KEY=ndis_support_items/ndis_support_items.json
# Optional: if set, any event under this prefix can trigger sync (useful for directory watch)
NDIS_CATALOG_WATCH_PREFIX=ndis_support_items/
# Optional override for object storage credentials
NDIS_CATALOG_ACCESS_KEY_ID=
NDIS_CATALOG_SECRET_ACCESS_KEY=

# Webhook auth for event-driven sync endpoint (/webhooks/ndis-catalog)
# Use either static token (Bearer, x-ndis-webhook-token, or ?token=...) or HMAC secret (x-ndis-signature).
NDIS_CATALOG_WEBHOOK_TOKEN=
NDIS_CATALOG_WEBHOOK_SECRET=

# Cloudflare R2 (required when NDIS_CATALOG_PROVIDER=r2)
R2_ACCOUNT_ID=your-r2-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=your-r2-bucket

# Google Cloud Storage HMAC keys (required when NDIS_CATALOG_PROVIDER=gcs)
GCS_HMAC_ACCESS_KEY_ID=
GCS_HMAC_SECRET_ACCESS_KEY=

# ============================================================================
# LOGGING & MONITORING (OPTIONAL)
# ============================================================================
LOG_LEVEL=info
DEBUG_MODE=false

# ============================================================================
# GRAFANA CONFIGURATION (OPTIONAL)
# ============================================================================
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin123

# ============================================================================
# CORS CONFIGURATION (PRODUCTION)
# ============================================================================
# ALLOWED_ORIGINS=https://yourdomain.com,https://app.yourdomain.com
